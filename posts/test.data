output frontpage
  Content-Type: [text/html; charset=utf-8]
  <!doctype html><html lang=en><head>
    <title>iio.ie</title>
    <meta charset=utf-8>
    <meta name=viewport content='width=device-width,initial-scale=1'>
    <link rel=icon href=favicon.ico>
    <link rel=stylesheet href=style.css>
    <link rel=alternate type=application/rss+xml title=iio.ie href=rss>
  </head><body>
  <pre id=eError class=cbgNegative hidden></pre>
  <p class=cBold># frontpage: this is a sample frontpage header.</p>
  
  <p>stuff that appears on the fronpage above the list of posts.</p>
  
  <p>2021 entries:</p>
  
  <ul><li> <a href='/theend'>@/theend</a>: sample final post.</li>
  <li> <a href='/samplebadhdr2'>@/samplebadhdr2</a>: a post with a mismatching header vs file name.</li>
  <li> <a href='/samplehtml'>@/samplehtml</a>: sample html page</li>
  <li> <a href='/samplegooddup'>@/samplegooddup</a>: a sample post with identical date.</li>
  <li> <a href='/samplegood'>@/samplegood</a>: a sample post.</li></ul>
  
  <p>2020 entries:</p>
  
  <ul><li> <a href='/sampleold'>@/sampleold</a>: a post from 2020.</li></ul>
  
  <p>2019 entries:</p>
  
  <ul><li> <a href='/sampleveryold'>@/sampleveryold</a>: a very old post from 2019.</li></ul>
  
  <script id=eTags type=application/json>{"testtag":["samplegood"]}</script>
  <p id=hFilterMessage>filtered entries:</p><ul id=hSelection hidden></ul><script src=frontpage.js></script>
  
  
  </body></html>
